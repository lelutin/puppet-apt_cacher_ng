{
  "name": "LeLutin-apt_cacher_ng",
  "version": "1.0.0",
  "author": "LeLutin",
  "summary": "Setup apt-cacher-ng for caching .deb packages",
  "license": "GPL-3.0+",
  "source": "https://github.com/lelutin/puppet-apt_cacher_ng",
  "project_page": "https://github.com/lelutin/puppet-apt_cacher_ng",
  "issues_url": "https://github.com/lelutin/puppet-apt_cacher_ng/issues",
  "dependencies": [
    {
      "name": "puppetlabs/stdlib",
      "version_requirement": ">= 4.6.0 < 10.0.0"
    }
  ],
  "requirements": [
    {
      "name": "puppet",
      "version_requirement": ">= 6.0 < 9.0.0"
    }
  ],
  "operatingsystem_support": [
    {
      "operatingsystem": "Debian",
      "operatingsystemrelease": [
        "12",
        "13"
      ]
    },
    {
      "operatingsystem": "Ubuntu",
      "operatingsystemrelease": [
        "22.04",
        "24.04"
      ]
    }
  ],
  "tags": [
    "apt-cacher-ng",
    "debian",
    "caching"
  ]
}
